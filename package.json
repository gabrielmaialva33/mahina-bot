{
  "name": "mahina-bot",
  "version": "4.0.0",
  "description": "MahinaBot is a music bot for Discord, written in Typescript, using Lavalink as the audio player.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabrielmaialva33/mahina-bot.git"
  },
  "keywords": [
    "discord",
    "music",
    "bot",
    "lavalink",
    "lavalink-client",
    "mahinabot",
    "typescript",
    "prisma"
  ],
  "author": "gabrielmaialva33",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gabrielmaialva33/mahina-bot/issues"
  },
  "homepage": "https://github.com/gabrielmaialva33/mahina-bot#readme",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf build && tsup",
    "start": "node dist/index.js",
    "start:max": "node --max-old-space-size=4096 --optimize_for_size dist/index.js",
    "start:dev": "nodemon",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev --name init",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "imports": {
    "#src/*": "./src/*.js",
    "#common/*": "./src/common/*.js",
    "#commands/*": "./src/commands/*.js",
    "#utils/*": "./src/utils/*.js"
  },
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "engines": {
    "node": ">=22.11.0"
  },
  "tsup": {
    "entry": [
      "src/**/*.ts"
    ],
    "format": [
      "esm"
    ],
    "splitting": false,
    "sourcemap": true,
    "clean": true,
    "minify": true,
    "bundle": true,
    "outDir": "dist"
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/app"
  },
  "prettier": "@adonisjs/prettier-config",
  "devDependencies": {
    "@adonisjs/eslint-config": "3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@types/express": "^5.0.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/i18n": "^0.13.12",
    "@types/multer": "^2.0.0",
    "@types/node": "^26.0.0",
    "@types/signale": "^1.4.7",
    "esbuild-copy-files": "^0.2.16",
    "eslint": "^10.5.0",
    "multer": "1.4.5-lts.1",
    "node-gyp": "^13.0.0",
    "node-polyfill-webpack-plugin": "^4.1.0",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.3",
    "tslib": "^2.8.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@dank074/discord-video-stream": "^6.0.0",
    "@discordjs/voice": "^0.19.2",
    "@distube/ytdl-core": "^4.16.12",
    "@prisma/client": "^6.19.3",
    "@qdrant/js-client-rest": "^1.18.0",
    "@top-gg/sdk": "^3.1.6",
    "axios": "^1.18.1",
    "bullmq": "^5.79.1",
    "crypto-browserify": "^3.12.1",
    "discord.js": "^14.26.4",
    "discord.js-selfbot-v13": "^3.7.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "genius-lyrics-api": "^3.2.1",
    "i18n": "^0.15.1",
    "ioredis": "^5.11.1",
    "lavalink-client": "^2.10.3",
    "module-alias": "^2.2.3",
    "multer": "2.2.0",
    "node-system-stats": "^2.0.5",
    "openai": "^6.44.0",
    "p-cancelable": "^4.0.1",
    "prism-media": "^1.3.5",
    "progress-estimator": "^0.3.1",
    "rimraf": "^6.0.1",
    "signale": "^1.4.0",
    "telegram": "^2.26.22",
    "topgg-autoposter": "^2.0.2",
    "undici": "^8.5.0",
    "youtube-dl-exec": "^3.1.8",
    "zod": "^4.4.3"
  },
  "signale": {
    "displayScope": true,
    "displayBadge": true,
    "displayDate": true,
    "displayFilename": true,
    "displayLabel": true,
    "displayTimestamp": true,
    "underlineLabel": true
  }
}
